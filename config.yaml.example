# =============================================================================
# dynhosts 設定ファイル
# =============================================================================
# このファイルを config.yaml にコピーして使用してください。
# 変更後はシステムトレイの「今すぐ更新」またはツールの再起動で反映されます。

settings:
  # hostsファイルの更新間隔（秒）
  # 3600 = 1時間 / 86400 = 1日
  update_interval: 3600

  # カスタム DNS サーバーの IP アドレス（空文字 = OS 既定の DNS を使用）
  # 例: "192.168.1.1"  /  "8.8.8.8"
  dns_server: ""

  # hostsファイルのパス（通常は変更不要）
  hosts_file: "C:\\Windows\\System32\\drivers\\etc\\hosts"

  # 更新前にバックアップを取るか
  backup: true

  # バックアップの保持世代数
  backup_count: 5

# =============================================================================
# 管理エントリー一覧
# =============================================================================
# alias   : DNS 解決する完全修飾ドメイン名（必須）
# name    : hosts に一緒に登録する短い名前（省略可）
# comment : hosts ファイル内に記録するコメント（省略可）
# enabled : false にすると hosts への反映をスキップ（省略時は true）
#
# ※ DNS に複数の IP が返ってきた場合は先頭の 1 件のみ登録します。
# =============================================================================

entries:
  - name: "dev.example.local"
    alias: "dev-alb-xxxx.ap-northeast-1.elb.amazonaws.com"
    comment: "開発サーバー"

  - name: "stg.example.local"
    alias: "stg-alb-xxxx.ap-northeast-1.elb.amazonaws.com"
    comment: "検証サーバー"
    enabled: false
